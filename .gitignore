# PRDX plugin .gitignore
# This file defines what should be ignored when the plugin itself is in version control

# IDE and editor files
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# Temporary files
*.tmp
*.bak
*.log

# Node modules (if any)
node_modules/

# Build artifacts
dist/
build/

# PRDX runtime state (not project docs)
.prdx/state/
.prdx/plans-setup-done

# User-specific context files
.claude/.prdx-context

# Test temporary files
tests/tmp/
