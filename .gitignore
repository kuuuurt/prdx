# PRDX plugin .gitignore
# This file defines what should be ignored when the plugin itself is in version control

# IDE and editor files
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# Temporary files
*.tmp
*.bak
*.log

# Node modules (if any)
node_modules/

# Build artifacts
dist/
build/

# Local metrics (these should never be committed to plugin repo)
.prdx/

# User-specific context files
.claude/.prdx-context

# Test temporary files
tests/tmp/
